BOT_TOKEN=your_telegram_token
SPIDER_HOST=dxspider
SPIDER_PORT=23
MY_CALL=YOURCALL
DEBUG_TELNET=0
CLUSTER_DB_NAME=your_db
CLUSTER_DB_USER=your_user
CLUSTER_DB_PASS=your_password

# -------------------------------------------------
# Telegram delivery tuning (workers + HTTP pool)
# Perfil base recomendado (carga media)
TG_POOL_SIZE=20
TG_POOL_TIMEOUT=10
TG_SEND_QUEUE_MAX=5000
TG_ENQUEUE_TIMEOUT=0.3
TG_DRAIN_TIMEOUT=15
TG_MIN_SENDER_WORKERS=10
TG_MAX_SENDER_WORKERS=64
TG_SCALE_UP_EVERY=50

# Opcionales de referencia:
# Carga baja:
# TG_POOL_SIZE=10
# TG_MIN_SENDER_WORKERS=4
# TG_MAX_SENDER_WORKERS=16
# TG_SCALE_UP_EVERY=80

# Carga alta:
# TG_POOL_SIZE=30
# TG_MIN_SENDER_WORKERS=12
# TG_MAX_SENDER_WORKERS=96
# TG_SCALE_UP_EVERY=35
